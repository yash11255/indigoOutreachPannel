# Copy to terraform.tfvars (gitignored) and fill in your own values.
# Never commit terraform.tfvars or set db_password here directly — pass it
# via TF_VAR_db_password instead.

ssh_key_pair_name = "your-ec2-key-pair-name"
allowed_ssh_cidr  = "203.0.113.4/32" # replace with YOUR IP, never 0.0.0.0/0
