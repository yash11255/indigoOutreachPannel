# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to the browser.
# Used by scripts/migrate-excel.ts and admin user-creation actions.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — an existing admin login, used by the Playwright E2E suite
# (tests/e2e) to authenticate. Without these, login-dependent tests are skipped.
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Optional — Scholarship Portal (ScholarsBox) external API key, org-scoped
# and admin-issued. Server-only: sent as the x-api-key request header, never
# in a query string or client-side code. If unset, the app behaves exactly
# as it does today — live sync is disabled, manual data only, no crash.
SCHOLARSBOX_API_KEY=
